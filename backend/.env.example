# comma-separated pairs: api_key:tenant_id
# example: COMPLIANCE_API_KEYS="demo-key:demo-tenant,acme-key:acme-finance"
COMPLIANCE_API_KEYS="demo-key:demo-tenant"

# jwt settings
COMPLIANCE_JWT_SECRET="dev-secret-change-me"
COMPLIANCE_JWT_ALG="HS256"
COMPLIANCE_TOKEN_MINUTES="480"
COMPLIANCE_INVITE_TTL_MINUTES="1440"

# seeded default user for first login
COMPLIANCE_ADMIN_EMAIL="founder@demo.local"
COMPLIANCE_ADMIN_PASSWORD="ChangeMe123!"
COMPLIANCE_ADMIN_TENANT="demo-tenant"
COMPLIANCE_ADMIN_ROLE="admin"

# optional custom sqlite path
# COMPLIANCE_DB_PATH="/absolute/path/to/copilot.db"
