# comma-separated pairs: api_key:tenant_id:role
# example: COMPLIANCE_API_KEYS="acme-key:acme-finance:analyst"
COMPLIANCE_API_KEYS=""

# allowed browser origins
COMPLIANCE_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# jwt settings
COMPLIANCE_JWT_SECRET="replace-with-a-strong-random-secret"
COMPLIANCE_JWT_ALG="HS256"
COMPLIANCE_TOKEN_MINUTES="480"
COMPLIANCE_INVITE_TTL_MINUTES="1440"
COMPLIANCE_WEBHOOK_SECRET="replace-with-a-strong-webhook-secret"
COMPLIANCE_ENV="development"

# seeded default user for first login
# set COMPLIANCE_ENABLE_PREVIEW_BOOTSTRAP=true only for local preview/demo use
COMPLIANCE_ENABLE_PREVIEW_BOOTSTRAP="false"
# set COMPLIANCE_ENABLE_PREVIEW_AUTH_METHODS=true only when you intentionally want preview OAuth / phone signup flows available
COMPLIANCE_ENABLE_PREVIEW_AUTH_METHODS="false"
COMPLIANCE_ADMIN_EMAIL=""
COMPLIANCE_ADMIN_PASSWORD=""
COMPLIANCE_ADMIN_TENANT=""
COMPLIANCE_ADMIN_ROLE="admin"

# optional custom sqlite path
# COMPLIANCE_DB_PATH="/absolute/path/to/copilot.db"

# optional sqlite URL form (currently sqlite URLs only; postgres URL support is planned)
# COMPLIANCE_DATABASE_URL="sqlite:////absolute/path/to/copilot.db"
