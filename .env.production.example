# Backend
COMPLIANCE_ENV=production
COMPLIANCE_ALLOWED_ORIGINS=https://your-frontend-domain.com
COMPLIANCE_JWT_SECRET=replace-with-strong-random-secret
COMPLIANCE_WEBHOOK_SECRET=replace-with-strong-random-secret
COMPLIANCE_API_KEYS=service-key:your-tenant:analyst
COMPLIANCE_DB_PATH=/data/compliance.db
# Optional database URL form.
# COMPLIANCE_DATABASE_URL=sqlite:////data/compliance.db
# COMPLIANCE_DATABASE_URL=postgresql://user:pass@db-host:5432/compliance
# Optional first admin bootstrap
COMPLIANCE_ADMIN_EMAIL=
COMPLIANCE_ADMIN_PASSWORD=
COMPLIANCE_ADMIN_TENANT=
COMPLIANCE_ADMIN_ROLE=admin

# Frontend
NEXT_PUBLIC_API_BASE=https://your-api-domain.com
NEXT_PUBLIC_API_KEY=
